    "@sxzz/eslint-config": "^7.8.3",
    "@sxzz/prettier-config": "^2.3.1",
    "@sxzz/test-utils": "^0.5.15",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260313.1",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "quansync": "^1.0.0",
    "rolldown": "1.0.0-rc.9",
    "tsdown": "^0.21.2",
    "tsdown-preset-sxzz": "^0.4.2",
