    "url": "git+https://github.com/quansync-dev/unplugin-quansync.git"
  },
  "bugs": {
    "url": "https://github.com/quansync-dev/unplugin-quansync/issues"
  },
  "keywords": [
    "async",
    "sync",
    "generator",
    "quansync",
    "unplugin",
    "vite",
    "webpack",
    "rspack",
    "rollup",
    "rolldown",
    "esbuild",
    "farm"
  ],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
